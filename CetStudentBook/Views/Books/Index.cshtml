@model IEnumerable<CetStudentBook.Models.Book>

@{
    ViewData["Title"] = "Kitaplar";
}

<h1>Kitaplar</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Yeni Kitap</a>
</p>

<table class="table table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.First().Name)</th>
            <th>@Html.DisplayNameFor(model => model.First().Author)</th>
            <th>@Html.DisplayNameFor(model => model.First().PublishDate)</th>
            <th>@Html.DisplayNameFor(model => model.First().PageCount)</th>
            <th>@Html.DisplayNameFor(model => model.First().IsSecondHand)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Author</td>
                <td>@item.PublishDate.ToShortDateString()</td>
                <td>@item.PageCount</td>
                <td>
                    @if (item.IsSecondHand)
                    {
                        <span>Evet</span>
                    }
                    else
                    {
                        <span>Hayir</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
